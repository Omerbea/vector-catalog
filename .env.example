# Environment variables for vector-catalog
# Copy this to .env and fill in your values.

# Google Gemini API key — required for DB-side embedding generation
# Get one at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# PostgreSQL password (optional — defaults to 'password' for local dev)
POSTGRES_PASSWORD=password

# Spring Boot datasource (used by the app service — added in S02)
SPRING_DATASOURCE_URL=jdbc:postgresql://database:5432/vectorcatalog
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=${POSTGRES_PASSWORD}
